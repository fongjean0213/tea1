rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'fong213.chang@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'order', 'createdAt']) && data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.order is number && 
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'categoryId', 'priceM', 'priceL', 'isActive', 'createdAt']) && data.keys().size() == 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.categoryId is string && isValidId(data.categoryId) &&
             data.priceM is number && data.priceM >= 0 &&
             data.priceL is number && data.priceL >= 0 &&
             data.isActive is bool &&
             data.createdAt is timestamp;
    }

    function isValidOrderItem(item) {
      return item.keys().hasAll(['productId', 'name', 'size', 'price', 'sugar', 'ice']) &&
             item.productId is string && item.productId.size() > 0 && item.productId.size() <= 128 &&
             item.name is string && item.name.size() > 0 && item.name.size() <= 100 &&
             item.size is string && item.size.size() > 0 && item.size.size() <= 10 &&
             item.price is number && item.price >= 0 &&
             item.sugar is string && item.sugar.size() > 0 && item.sugar.size() <= 20 &&
             item.ice is string && item.ice.size() > 0 && item.ice.size() <= 20;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'status', 'total', 'items', 'createdAt', 'updatedAt']) && data.keys().size() == 6 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.status is string && data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 && isValidOrderItem(data.items[0]) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming()) && incoming().createdAt == request.time;
      allow update: if false; // immutable for now
      allow delete: if isAdmin() && isValidId(adminId);
      allow list: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true; // Public can read
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'order']) &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && 
                    exists(/databases/$(database)/documents/categories/$(incoming().categoryId)) &&
                    incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'categoryId', 'priceM', 'priceL', 'isActive']) &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && isValidId(orderId) && (isAdmin() || existing().userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && 
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (
                      isAdmin() || // Admins can change status to anything
                      (
                        existing().status == 'pending' && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                        incoming().status == 'cancelled'
                      )
                    );
      allow delete: if false; // orders cannot be deleted
    }

  }
}
